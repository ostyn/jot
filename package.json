{
    "name": "jot",
    "packageManager": "yarn@4.5.3",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "nodeLinker": "node-modules",
    "scripts": {
        "generate:movie-ids": "node ./scripts/generate-movie-ids.mjs",
