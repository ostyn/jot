        "body-scroll-lock-upgrade": "^1.1.0",
        "date-fns": "^4.1.0",
        "date-fns-tz": "^3.2.0",
        "dexie": "^4.0.10",
        "escape-string-regexp": "^5.0.0",
        "leaflet": "^1.9.4",
        "lit": "^3.2.1",
        "lucide": "^0.464.0",
        "mobx": "^6.13.5",
